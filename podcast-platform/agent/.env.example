# Database (Railway provides this automatically as $DATABASE_URL)
DATABASE_URL=postgresql+asyncpg://podcast:podcast@localhost:5432/podcast

# S3-compatible storage (AWS S3 or Cloudflare R2)
S3_BUCKET=your-bucket-name
S3_ENDPOINT_URL=https://your-account.r2.cloudflarestorage.com  # omit for AWS S3
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key

# CORS: comma-separated list of allowed origins, or * for all
ALLOWED_ORIGINS=https://your-app.vercel.app,http://localhost:5173
